{
  "name": "news_webdev_root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"bun run dev:frontend\" \"bun run dev:backend\"",
    "dev:frontend": "cd frontend && bun run dev",
    "dev:backend": "cd backend && bun run dev",
    "install:all": "bun install && cd frontend && bun install && cd ../backend && bun install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
